{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Urls": "http://localhost:5000",
  "DbConnections": {
    "MasterDB": {
      "ConnectionString": "Host=localhost;Port=5432;Database=xiaoli;Username=postgres;"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "permission-route": {
        "ClusterId": "permission-cluster",
        "Match": {
          "Path": "/api/Permission/{**catch-all}"
        }
      },
      "message-route": {
        "ClusterId": "message-cluster",
        "Match": {
          "Path": "/api/Message/{**catch-all}"
        }
      },
      "hubs-route": {
        "ClusterId": "message-cluster",
        "Match": {
          "Path": "/hubs/{**catch-all}"
        }
      },
      "agent-route": {
        "ClusterId": "agent-cluster",
        "Match": {
          "Path": "/api/Agent/{**catch-all}"
        }
      },
      "platform-route": {
        "ClusterId": "platform-cluster",
        "Match": {
          "Path": "/api/Platform/{**catch-all}"
        }
      },
      "shop-route": {
        "ClusterId": "shop-cluster",
        "Match": {
          "Path": "/api/Shop/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "permission-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5001"
          }
        }
      },
      "message-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5002"
          }
        }
      },
      "agent-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5003"
          }
        }
      },
      "platform-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5004"
          }
        }
      },
      "shop-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5005"
          }
        }
      }
    }
  }
}
